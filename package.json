{
  "name": "doit",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @doit/web dev",
    "build": "pnpm --filter @doit/web build",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
