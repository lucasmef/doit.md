# Copie este arquivo para .env e preencha os valores reais
# Nunca comite o .env com valores reais

# Em dev local, deixe DATABASE_URL vazio para usar SQLite em .data/doit-dev.sqlite.
# Em VPS/dev e producao, configure Postgres:
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/doitmd

NEXTAUTH_SECRET=<replace-with-random-secret>
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_REDIRECT_URI=https://<your-domain>/api/google/callback
