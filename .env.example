# Copie este arquivo para .env e preencha os valores reais
# Nunca comite o .env com valores reais

# Em dev local, deixe DATABASE_URL vazio para usar SQLite em .data/doit-dev.sqlite.
# Em VPS/dev e producao, configure Postgres:
DATABASE_URL=postgresql://USER:PASS@HOST:5432/doitmd

NEXTAUTH_SECRET=gere_um_secret_com_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://SEU_DOMINIO.com.br/api/google/callback
