[Unit]
Description=Doit Web Application (Development)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/doit-dev
Environment=NODE_ENV=production
Environment=PORT=3001
ExecStart=/usr/bin/pnpm --filter @doit/web start
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
