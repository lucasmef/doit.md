[Unit]
Description=Doit Web Application (Production)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/var/www/doit
Environment=NODE_ENV=production
Environment=PORT=3000
ExecStart=/usr/bin/pnpm --filter @doit/web start
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
