# Copy to /srv/doit/<prod|dev>/doit-config/web.env on the VPS.
# Do not commit real values.

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/doitmd
NEXTAUTH_SECRET=<replace-with-random-secret>
NEXTAUTH_URL=https://<doit-public-domain>
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>
GOOGLE_REDIRECT_URI=https://<doit-public-domain>/api/google/callback
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>
VAPID_EMAIL=mailto:<admin-email@example.com>
CRON_SECRET=<replace-with-random-cron-secret>
NOTIFICATION_LOOKAHEAD_MINUTES=5
RESEND_API_KEY=<resend-api-key>
EMAIL_FROM=doit.md <notifications@example.com>
