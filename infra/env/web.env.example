# Copy to /srv/doit/<prod|dev>/doit-config/web.env on the VPS.
# Do not commit real values.

DATABASE_URL=postgresql://USER:PASS@HOST:5432/doitmd
NEXTAUTH_SECRET=generate_a_strong_random_secret
NEXTAUTH_URL=https://DOIT_PUBLIC_DOMAIN
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://DOIT_PUBLIC_DOMAIN/api/google/callback
