# Copy to /srv/doit/<prod|dev>/doit-config/web.env on the VPS.
# Do not commit real values.

MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/doitmd?retryWrites=true&w=majority
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_or_test_...
CLERK_SECRET_KEY=sk_live_or_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://DOIT_PUBLIC_DOMAIN/api/google/callback
